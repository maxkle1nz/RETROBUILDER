# ─── RETROBUILDER Environment Configuration ───

# AI Provider: xai | bridge
# xai = xAI Grok (https://api.x.ai)
# bridge = THE BRIDGE local proxy (http://127.0.0.1:7788)
AI_PROVIDER="xai"

# ─── xAI (Grok) ───
XAI_API_KEY="YOUR_XAI_API_KEY"
# XAI_MODEL="grok-3-mini"  # Optional: override default model

# ─── THE BRIDGE (local) ───
# THEBRIDGE_URL="http://127.0.0.1:7788/v1"
# THEBRIDGE_MODEL="github-copilot/gpt-5.4"
# THEBRIDGE_HTTP_TOKEN=""  # Optional: bearer auth token