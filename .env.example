# ─── RETROBUILDER Environment Configuration ───

# Server
PORT=7777

# AI Provider: bridge | xai | gemini | openai
# xai = xAI Grok (https://api.x.ai)
# gemini = Google Gemini
# bridge = THE BRIDGE local proxy (http://127.0.0.1:7788)
AI_PROVIDER="bridge"

# ─── xAI (Grok) ───
# XAI_API_KEY="xai-..."
# XAI_MODEL="grok-3-mini"  # Optional: override default model

# ─── Google Gemini ───
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# GEMINI_API_KEYS="key1,key2,key3"   # Optional: comma-separated rotation pool
# GEMINI_MODEL="gemini-3-pro-image-preview"

# ─── OpenAI ───
# OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
# OPENAI_MODEL="gpt-5.4"

# ─── THE BRIDGE (local) ───
# THEBRIDGE_URL="http://127.0.0.1:7788/v1"
# THEBRIDGE_MODEL="gpt-5.5"
# THEBRIDGE_HTTP_TOKEN=""  # Optional: bearer auth token
# THEBRIDGE_AUTH_PROFILE="openai-codex:default"  # Optional: selected OpenClaw auth profile
# OPENCLAW_AUTH_PROFILES_PATH="/absolute/path/to/auth-profiles.json"  # Optional: profile store override for live Bridge lanes
# THEBRIDGE_COMMAND="/absolute/path/to/thebridge"  # Optional: override executable discovery
# THEBRIDGE_DONOR_ROOT="/absolute/path/to/the-bridge"  # Optional: standalone donor bridge root
# CODEX_BINARY="/absolute/path/to/newer/codex"  # Optional: newer Codex CLI for newly released models
# RETROBUILDER_CODEX_EXEC_TIMEOUT_MS=180000
# RETROBUILDER_ENABLE_LOCAL_CODEX_FALLBACK=0  # Optional: set 1 only for trusted local JSON fallback experiments
# THEBRIDGE_AUTO_START="0"  # Optional: opt out. Default is auto-start with Retrobuilder.
# THEBRIDGE_KEEPALIVE_INTERVAL_MS=30000

# ─── Local API guard (required when binding to 0.0.0.0 or ::) ───
# RETROBUILDER_LOCAL_API_TOKEN="replace-with-a-long-random-token"
# VITE_RETROBUILDER_LOCAL_API_TOKEN="same-token-for-local-dev-ui"

# ─── Design reference catalog (optional) ───
# RETROBUILDER_21ST_CATALOG_ROOT="/absolute/path/to/21st-catalog/components"

# ─── M1ND MCP (optional) ───
# Override the m1nd binary used by the backend bridge when PATH points at an older global install.
# M1ND_MCP_COMMAND="/absolute/path/to/your/m1nd-mcp"
# Retrobuilder uses m1nd over stdio, so the backend child disables the embedded GUI by default.
# M1ND_MCP_ARGS="--no-gui"
